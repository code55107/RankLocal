# ---- App ----
NODE_ENV=development
PORT=3002
PUBLIC_API_URL=http://localhost:3002
# Public URL of the RankLocal frontend — used to build absolute deeplinks in
# transactional emails (audit complete CTA).
FRONTEND_URL=http://localhost:3000

# ---- PostgreSQL (Prisma DSN) ----
DATABASE_URL=postgresql://ranklocal:ranklocal@localhost:5432/ranklocal?schema=public

# ---- Google APIs ----
# Places API (New) — search/details/nearby
GOOGLE_PLACES_API_KEY=AIza_xxx_replace_me
# PageSpeed Insights API
GOOGLE_PAGESPEED_API_KEY=AIza_xxx_replace_me

# ---- AI ----
ANTHROPIC_API_KEY=sk-ant-xxx_replace_me

# ---- Google OAuth (sign-in) ----
# Required only for POST /auth/google. Create credentials in the GCP Console;
# the redirect URI is supplied per-request by the frontend BFF.
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=

# ---- Email (Resend) ----
RESEND_API_KEY=re_xxx_replace_me
MAIL_FROM="RankLocal <audits@ranklocal.com>"

# ---- Pipeline & rate limit ----
# Max pipeline duration before marking failed (ms).
AUDIT_TIMEOUT_MS=120000
# Max audits per IP per rolling 1-hour window.
RATE_LIMIT_MAX_PER_HOUR=10

# ---- CORS (comma-separated origins) ----
CORS_ORIGINS=http://localhost:3000,https://ranklocal.com
